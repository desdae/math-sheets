{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "mathsheets-api",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["nodejs_compat"],
  "keep_vars": true,
  "observability": {
    "enabled": true
  },
  "vars": {
    "NODE_ENV": "production",
    "APP_BASE_URL": "https://mathsheets-app.desdae.workers.dev",
    "GOOGLE_CALLBACK_URL": "https://mathsheets-api.desdae.workers.dev/api/auth/google/callback",
    "COOKIE_DOMAIN": "mathsheets-api.desdae.workers.dev"
  },
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "c1200f3cd62344398a7b69cd15395203",
      "localConnectionString": "postgres://postgres:postgres@localhost:5433/mathsheets"
    }
  ]
}
