{
  "name": "mathsheets",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "test": "npm run test --workspace backend && npm run test --workspace frontend",
    "check:e2e-config": "node -e \"const fs=require('fs'); if(!fs.existsSync('playwright.config.ts')) throw new Error('playwright.config.ts missing'); console.log('playwright config ok')\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "npm run migrate --workspace backend",
    "db:seed": "npm run seed --workspace backend",
    "db:reset:e2e": "tsx e2e/utils/db-reset.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.20.5"
  }
}
